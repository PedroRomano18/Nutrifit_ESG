## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (DotSettings)
*.DotSettings.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bbin/
obj/
external/
node_modules/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if using tasks.json or launch.json
#.vscode/

# Compiled files
*.dll
*.exe
*.pdb
*.suo

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using tasks.json or launch.json
#.vscode/

# Entity Framework Core-specific files
*.Design.Common.props

# Bicep-specific files
# Generated bicep parameters file from arm template (if using bicep)
# *.bicepparam

# Others
.DS_Store
*.swp
*.bak
*~
[Tt]est[Rr]esults/
